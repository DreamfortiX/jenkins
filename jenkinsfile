pipeline {
    agent any

    environment {
        NODE_ENV = "production"
    }

    stages {

        stage('Checkout') {
            steps {
                echo "Cloning repository..."
                checkout scm
            }
        }

        stage('Install Backend Dependencies') {
            steps {
                dir('backend') {
                    sh 'npm install'
                }
            }
        }

        stage('Install Frontend Dependencies') {
            steps {
                dir('frontend') {
                    sh 'npm install'
                }
            }
        }

        stage('Build Frontend') {
            steps {
                dir('frontend') {
                    sh 'npm run build'
                }
            }
        }

        stage('Test') {
            steps {
                echo "No tests configured."
            }
        }

        stage('Build Docker Images') {
            steps {
                echo "Docker build stage will be added later."
            }
        }

        stage('Deploy') {
            steps {
                echo "Deployment stage will be added later."
            }
        }
    }

    post {
        always {
            echo "Pipeline Finished"
        }

        success {
            echo "Build Successful!"
        }

        failure {
            echo "Build Failed!"
        }
    }
}